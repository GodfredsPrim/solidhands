# SolidHands environment configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8080
NODE_ENV=development

# Email Configuration (Gmail SMTP)
# Gmail requires an App Password (not regular password)
# Get one at: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-gmail-app-password

# Company Configuration
COMPANY_EMAIL=company-email@example.com

# Admin Authentication
ADMIN_PASSWORD=change-this-to-a-strong-password-for-admin-login
ADMIN_JWT_SECRET=change-this-to-a-random-32-character-secret-key
ADMIN_TOKEN_EXPIRY=2h

# CORS Configuration (for browser requests)
# Local development: http://localhost:8080
# Production (Render): https://your-app-name.onrender.com
CORS_ORIGIN=http://localhost:8080
